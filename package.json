    "start": "npm run build && cd backend && node server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "nodemailer": "^8.0.9",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0"
  }
}
